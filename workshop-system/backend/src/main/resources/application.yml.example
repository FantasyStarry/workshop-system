server:
  port: 8080

spring:
  jackson:
    date-format: yyyy-MM-dd HH:mm:ss
    time-zone: Asia/Shanghai
    serialization:
      write-dates-as-timestamps: false
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/workshop_db?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
    username: your_db_username
    password: your_db_password
  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 100MB
    encoding:
      charset: UTF-8
      enabled: true
      force: true

mybatis-plus:
  mapper-locations: classpath:mapper/*.xml
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

jwt:
  secret: your-jwt-secret-key-at-least-32-characters-long
  expiration: 86400000

file:
  upload:
    path: ./uploads

springdoc:
  swagger-ui:
    path: /swagger-ui.html

knife4j:
  enable: true

wx:
  appid: your-wechat-miniprogram-appid
  secret: your-wechat-miniprogram-secret
  mock: false
