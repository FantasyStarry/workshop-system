.search-bar {
  display: flex;
  gap: 10px;
  margin-bottom: 16px;
}

.search-input {
  flex: 1;
  background: #fff;
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 14px;
  border: 1px solid #e8e8e8;
}

.scan-btn {
  width: 70px;
  background: #1677ff;
  color: #fff;
  font-size: 14px;
  border-radius: 8px;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
}

.card-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px solid #fafafa;
}

.info-row .label {
  color: #999;
  font-size: 14px;
}

.info-row .value {
  color: #333;
  font-size: 14px;
  font-weight: 500;
}

.info-row .value.highlight {
  color: #1677ff;
  font-weight: bold;
}

.empty {
  text-align: center;
  color: #999;
  padding: 24px 0;
  font-size: 14px;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 80px 0;
  font-size: 14px;
}

/* Timeline 时间线 */
.timeline {
  display: flex;
  flex-direction: column;
  padding-left: 16px;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-bottom: 20px;
  min-height: 60px;
}

.dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #ddd;
  margin-right: 14px;
  margin-top: 4px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.dot.active {
  background: #1677ff;
  box-shadow: 0 0 0 3px rgba(22, 119, 255, 0.25);
}

.line {
  position: absolute;
  left: 4px;
  top: 18px;
  bottom: 0;
  width: 2px;
  background: #e8e8e8;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.content .stage {
  font-size: 15px;
  font-weight: 500;
  color: #333;
}

.content .time {
  font-size: 12px;
  color: #999;
}

.content .op {
  font-size: 12px;
  color: #666;
}

.content .loc {
  font-size: 12px;
  color: #999;
}
