<view class="container">
  <!-- 搜索区 -->
  <view class="search-bar">
    <input class="search-input" placeholder="扫描或输入二维码" value="{{qrContent}}" bindinput="onInput" />
    <button class="scan-btn" bindtap="startScan">扫码</button>
  </view>

  <!-- 查询结果 -->
  <view class="result" wx:if="{{result}}">
    <view class="card">
      <view class="card-title">{{result.productName}}</view>
      <view class="info-row"><text class="label">订单号</text><text class="value">{{result.orderNo}}</text></view>
      <view class="info-row"><text class="label">当前环节</text>
        <text class="value highlight">{{result.currentStageName || '待生产'}}</text>
      </view>
    </view>

    <!-- 完整流转时间线 -->
    <view class="card">
      <view class="card-title">流转记录</view>
      <view wx:if="{{records.length === 0}}" class="empty">暂无记录</view>
      <view wx:else class="timeline">
        <view wx:for="{{records}}" wx:key="id" class="timeline-item">
          <view class="dot {{index === records.length - 1 ? 'active' : ''}}"></view>
          <view wx:if="{{index < records.length - 1}}" class="line"></view>
          <view class="content">
            <text class="stage">{{item.stageName}}</text>
            <text class="time">{{item.scanTime}}</text>
            <text class="op">操作人：{{item.operatorName}}</text>
            <text wx:if="{{item.location}}" class="loc">📍 {{item.location}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:else>
    <text>请扫描二维码或输入二维码内容查询</text>
  </view>
</view>
