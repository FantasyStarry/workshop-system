.container {
  padding: 40rpx;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 64rpx 40rpx 48rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #F1F5F9;
  width: 100%;
}

.result-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.success-icon {
  background: #ECFDF5;
}

.error-icon {
  background: #FEF2F2;
}

.check-mark {
  width: 48rpx;
  height: 28rpx;
  border-left: 6rpx solid #059669;
  border-bottom: 6rpx solid #059669;
  transform: rotate(-45deg);
  margin-top: -8rpx;
}

.cross-mark {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.cross-mark::before,
.cross-mark::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 40rpx;
  height: 4rpx;
  background: #DC2626;
  border-radius: 2rpx;
}

.cross-mark::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.cross-mark::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.result-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 32rpx;
  letter-spacing: -0.5rpx;
}

.result-message {
  display: block;
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 40rpx;
}

.result-info {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid #F1F5F9;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  font-size: 26rpx;
  color: #94A3B8;
}

.info-row .value {
  font-size: 26rpx;
  color: #0F172A;
  font-weight: 500;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  border: none;
}

.action-btn::after {
  border: none;
}
