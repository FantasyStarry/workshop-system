<view class="container">
  <view class="result-card" wx:if="{{success}}">
    <view class="result-icon success">✓</view>
    <text class="result-title">上报成功</text>
    <view class="result-info">
      <view class="info-row">
        <text class="label">产品名称</text>
        <text class="value">{{productName}}</text>
      </view>
      <view class="info-row">
        <text class="label">完成工序</text>
        <text class="value">{{stageName}}</text>
      </view>
      <view class="info-row">
        <text class="label">上报时间</text>
        <text class="value">{{currentTime}}</text>
      </view>
    </view>
    <view class="result-actions">
      <button class="action-btn primary" bindtap="goHome">返回首页</button>
      <button class="action-btn secondary" bindtap="goScan">继续扫码</button>
    </view>
  </view>

  <view class="result-card" wx:else>
    <view class="result-icon error">✗</view>
    <text class="result-title">上报失败</text>
    <text class="result-message">请检查网络连接后重试</text>
    <view class="result-actions">
      <button class="action-btn primary" bindtap="goBack">返回重试</button>
    </view>
  </view>
</view>
