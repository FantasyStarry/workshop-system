<view class="container">
  <view class="scan-area">
    <view class="scan-icon" bindtap="startScan">
      <text class="iconfont">📷</text>
      <text class="scan-text">点击扫码</text>
      <text class="scan-desc">扫描产品二维码查看详情</text>
    </view>
  </view>
  
  <view class="manual-input">
    <view class="divider">
      <text class="divider-text">或手动输入</text>
    </view>
    <input class="input" placeholder="请输入二维码内容" value="{{qrContent}}" bindinput="onInputChange" />
    <button class="btn" bindtap="onQuery">查询</button>
  </view>
</view>
