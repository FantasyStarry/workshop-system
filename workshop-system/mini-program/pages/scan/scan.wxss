.container {
  padding: 32rpx;
}

.scan-area {
  background: linear-gradient(135deg, #4F46E5 0%, #3730A3 100%);
  border-radius: 28rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(79, 70, 229, 0.3);
}

.scan-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.scan-frame {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}

.scan-line-anim {
  position: absolute;
  top: 0;
  left: 8rpx;
  right: 8rpx;
  height: 3rpx;
  background: rgba(255, 255, 255, 0.9);
  animation: scanMove 2s ease-in-out infinite;
}

@keyframes scanMove {
  0% { top: 8rpx; }
  50% { top: 52rpx; }
  100% { top: 8rpx; }
}

.scan-text {
  display: block;
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.scan-hint {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
}

.history-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F1F5F9;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.history-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #4F46E5;
  flex-shrink: 0;
}

.item-info {
  display: flex;
  flex-direction: column;
}

.item-product {
  font-size: 28rpx;
  color: #0F172A;
  font-weight: 500;
}

.item-stage {
  font-size: 24rpx;
  color: #4F46E5;
  margin-top: 4rpx;
  font-weight: 500;
}

.item-time {
  font-size: 22rpx;
  color: #94A3B8;
  flex-shrink: 0;
}
