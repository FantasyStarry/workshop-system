.scan-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.scan-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200px;
  height: 200px;
  border-radius: 50%;
  border: 4px dashed #1677ff;
  background: #e6f0ff;
}

.iconfont {
  font-size: 48px;
  line-height: 1;
}

.scan-text {
  font-size: 18px;
  font-weight: bold;
  color: #1677ff;
  margin-top: 12px;
}

.scan-desc {
  font-size: 12px;
  color: #999;
  margin-top: 6px;
}

.divider {
  display: flex;
  align-items: center;
  margin: 24px 0 16px;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #ddd;
}

.divider-text {
  padding: 0 16px;
  color: #999;
  font-size: 13px;
}

.manual-input {
  padding: 0 16px;
}

.input {
  background: #f5f5f5;
  border-radius: 8px;
  padding: 12px 16px;
  font-size: 14px;
  width: 100%;
  box-sizing: border-box;
}

.btn {
  margin-top: 12px;
  background: #1677ff;
  color: #fff;
  border-radius: 8px;
  font-size: 16px;
  width: 100%;
}
