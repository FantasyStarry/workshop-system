<view class="container">
  <!-- 选择环节 -->
  <view class="card">
    <view class="card-title">选择生产环节</view>
    <view class="stage-list">
      <view wx:for="{{availableStages}}" wx:key="id"
        class="stage-item {{item.id === selectedStageId ? 'active' : ''}}"
        bindtap="selectStage" data-id="{{item.id}}">
        <text class="stage-seq">{{item.stageSeq}}</text>
        <text class="stage-name">{{item.stageName}}</text>
        <text class="stage-check" wx:if="{{item.id === selectedStageId}}">✓</text>
      </view>
    </view>
  </view>

  <!-- 填写信息 -->
  <view class="card" wx:if="{{selectedStageId}}">
    <view class="card-title">填写信息</view>
    <view class="form-item">
      <text class="label">作业位置</text>
      <input class="input" placeholder="如：1号生产线A区" value="{{location}}" bindinput="onLocationInput" />
    </view>
    <view class="form-item">
      <text class="label">温度 (°C)</text>
      <input class="input" type="digit" placeholder="如：25.0" value="{{temperature}}" bindinput="onTempInput" />
    </view>
    <view class="form-item">
      <text class="label">湿度 (%)</text>
      <input class="input" type="digit" placeholder="如：60.0" value="{{humidity}}" bindinput="onHumidityInput" />
    </view>
    <view class="form-item">
      <text class="label">现场照片</text>
      <view class="photo-area" bindtap="takePhoto">
        <image wx:if="{{photoUrl}}" src="{{photoUrl}}" mode="aspectFill" class="photo-preview" />
        <text wx:else class="photo-placeholder">+ 拍照</text>
      </view>
    </view>
    <view class="form-item">
      <text class="label">备注</text>
      <input class="input" placeholder="备注信息（选填）" value="{{remark}}" bindinput="onRemarkInput" />
    </view>
  </view>

  <!-- 提交按钮 -->
  <button class="btn-primary submit-btn" wx:if="{{selectedStageId}}" bindtap="submitReport" loading="{{submitting}}">
    确认上报
  </button>
</view>
