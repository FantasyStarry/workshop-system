.container {
  padding: 0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.header-section {
  background: linear-gradient(160deg, #0F172A 0%, #1E293B 100%);
  padding: 100rpx 60rpx 80rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.header-section::after {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79, 70, 229, 0.15) 0%, transparent 70%);
}

.logo-mark {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #4F46E5, #818CF8);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(79, 70, 229, 0.35);
}

.logo-letter {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.brand-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #F1F5F9;
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
}

.brand-subtitle {
  display: block;
  font-size: 26rpx;
  color: #64748B;
  letter-spacing: 2rpx;
}

.brand-divider {
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #4F46E5, #818CF8);
  border-radius: 2rpx;
  margin: 36rpx auto 0;
}

.form-section {
  flex: 1;
  padding: 40rpx 40rpx 60rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 1;
}

.login-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #F1F5F9;
}

.login-header {
  margin-bottom: 40rpx;
}

.login-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 8rpx;
  letter-spacing: -0.5rpx;
}

.login-desc {
  display: block;
  font-size: 26rpx;
  color: #94A3B8;
}

.wx-login-btn {
  width: 100%;
  height: 100rpx;
  background: #4F46E5;
  border-radius: 20rpx;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(79, 70, 229, 0.25);
}

.wx-login-btn::after {
  border: none;
}
