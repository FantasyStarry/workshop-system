<view class="container">
  <!-- 产品基本信息 -->
  <view class="card">
    <view class="card-title">产品信息</view>
    <view class="info-row"><text class="label">订单号</text><text class="value">{{productInfo.orderNo}}</text></view>
    <view class="info-row"><text class="label">产品名称</text><text class="value">{{productInfo.productName}}</text></view>
    <view class="info-row"><text class="label">当前环节</text>
      <text class="value highlight">{{productInfo.currentStageName || '待生产'}}</text>
    </view>
    <view class="info-row"><text class="label">状态</text>
      <text class="value status-{{productInfo.status}}">{{statusText}}</text>
    </view>
  </view>

  <!-- 生产环节进度 Steps -->
  <view class="card">
    <view class="card-title">生产进度</view>
    <view class="steps">
      <view wx:for="{{stages}}" wx:key="id" class="step {{item.status}}">
        <view class="step-dot"></view>
        <view class="step-line" wx:if="{{index < stages.length - 1}}"></view>
        <text class="step-name">{{item.stageName}}</text>
      </view>
    </view>
  </view>

  <!-- 流转记录 Timeline -->
  <view class="card">
    <view class="card-title">流转记录</view>
    <view wx:if="{{records.length === 0}}" class="empty">暂无流转记录</view>
    <view wx:else class="timeline">
      <view wx:for="{{records}}" wx:key="id" class="timeline-item">
        <view class="timeline-dot"></view>
        <view class="timeline-content">
          <text class="stage-name">{{item.stageName}}</text>
          <text class="time">{{item.scanTime}}</text>
          <text class="operator">操作人：{{item.operatorName}}</text>
          <text wx:if="{{item.location}}">位置：{{item.location}}</text>
          <text wx:if="{{item.qcResult === 1}}" class="qc-pass">质检通过</text>
          <text wx:if="{{item.qcResult === 2}}" class="qc-fail">质检不通过</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 上报进度按钮 -->
  <view class="fixed-bottom" wx:if="{{productInfo.status !== 2}}">
    <button class="btn-primary" bindtap="goReport">上报进度</button>
  </view>
</view>
