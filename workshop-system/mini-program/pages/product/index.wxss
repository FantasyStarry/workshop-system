.card-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px solid #fafafa;
}

.info-row .label {
  color: #999;
  font-size: 14px;
}

.info-row .value {
  color: #333;
  font-size: 14px;
  font-weight: 500;
}

.info-row .value.highlight {
  color: #1677ff;
  font-weight: bold;
}

.status-0 { color: #999; }
.status-1 { color: #1677ff; }
.status-2 { color: #52c41a; }
.status-3 { color: #ff4d4f; }

/* Steps 进度条 */
.steps {
  display: flex;
  flex-direction: column;
  padding-left: 20px;
}

.step {
  display: flex;
  align-items: center;
  position: relative;
  padding: 10px 0;
}

.step-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: #ddd;
  margin-right: 8px;
  flex-shrink: 0;
}

.step.finish .step-dot {
  background: #52c41a;
}

.step.process .step-dot {
  background: #1677ff;
  box-shadow: 0 0 0 4px rgba(22, 119, 255, 0.2);
}

.step.wait .step-dot {
  background: #ddd;
}

.step-line {
  position: absolute;
  left: 5px;
  top: 22px;
  width: 2px;
  height: calc(100% - 12px);
  background: #ddd;
}

.step.finish .step-line {
  background: #52c41a;
}

.step-name {
  font-size: 14px;
  color: #333;
}

.step.finish .step-name {
  color: #52c41a;
}

.step.process .step-name {
  color: #1677ff;
  font-weight: bold;
}

.empty {
  text-align: center;
  color: #999;
  padding: 24px 0;
  font-size: 14px;
}

/* Timeline 时间线 */
.timeline {
  padding-left: 16px;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-bottom: 16px;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 3px;
  top: 10px;
  bottom: 0;
  width: 2px;
  background: #e8e8e8;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #1677ff;
  margin-right: 12px;
  margin-top: 6px;
  flex-shrink: 0;
}

.timeline-content {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.timeline-content .stage-name {
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

.timeline-content .time {
  font-size: 12px;
  color: #999;
}

.timeline-content .operator {
  font-size: 12px;
  color: #666;
}

.qc-pass {
  color: #52c41a;
  font-size: 12px;
}

.qc-fail {
  color: #ff4d4f;
  font-size: 12px;
}

/* 底部固定按钮 */
.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.06);
}

.fixed-bottom .btn-primary {
  width: 100%;
  padding: 12px 0;
  font-size: 16px;
  border-radius: 8px;
}
