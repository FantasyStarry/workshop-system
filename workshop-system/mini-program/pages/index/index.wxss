.container {
  padding: 0;
  min-height: 100vh;
  background: var(--bg-page);
}

.header-section {
  background: linear-gradient(160deg, #0F172A 0%, #1E293B 100%);
  padding: 48rpx 40rpx 64rpx;
  position: relative;
  overflow: hidden;
}

.header-section::after {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79, 70, 229, 0.12) 0%, transparent 70%);
}

.greeting-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #F1F5F9;
  letter-spacing: 1rpx;
  margin-bottom: 6rpx;
}

.greeting-sub {
  display: block;
  font-size: 22rpx;
  color: #475569;
  letter-spacing: 2rpx;
}

.content-area {
  padding: 0 32rpx 32rpx;
  margin-top: -24rpx;
  position: relative;
  z-index: 1;
}

.action-card {
  background: linear-gradient(135deg, #4F46E5 0%, #3730A3 100%);
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(79, 70, 229, 0.3);
  margin-bottom: 24rpx;
}

.action-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.action-icon-inner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 8rpx;
  position: relative;
}

.scan-line {
  position: absolute;
  top: 50%;
  left: 8rpx;
  right: 8rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.8);
}

.scan-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 8rpx;
  height: 8rpx;
  margin: -4rpx 0 0 -4rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

.action-title {
  display: block;
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stats-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F1F5F9;
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 28rpx;
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #4F46E5;
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 500;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F1F5F9;
}

.tip-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F1F5F9;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.tip-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #EEF2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #4F46E5;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 6rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: #94A3B8;
  line-height: 1.6;
}
