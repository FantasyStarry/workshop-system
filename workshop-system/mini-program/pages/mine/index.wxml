<view class="container">
  <view class="user-card">
    <image class="avatar" src="/images/avatar.png" mode="aspectFill" />
    <text class="name">{{userInfo.realName || '生产人员'}}</text>
    <text class="dept">{{userInfo.deptName || '生产部'}}</text>
  </view>

  <view class="card menu-list">
    <view class="menu-item" bindtap="goScanHistory">
      <text class="menu-text">扫码记录</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="logout">
      <text class="menu-text">退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="version">
    <text>车间管理系统 v1.0.0</text>
  </view>
</view>
